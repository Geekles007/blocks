{
  "name": "blocks-www",
  "version": "0.0.0",
  "private": true,
  "description": "blocks.ibird.dev — gallery + detail pages for the blocks catalogue. Mounts the real blocks in live previews.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-blocks.mjs && node scripts/copy-registry.mjs",
    "dev": "next dev --port 3200",
    "prebuild": "node scripts/copy-blocks.mjs && node scripts/copy-registry.mjs",
    "build": "next build",
    "start": "next start --port 3200",
    "pretypecheck": "node scripts/copy-blocks.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "framer-motion": "^11.15.0",
    "next": "^15.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3"
  }
}
